# Copy this file to `.env.local` and fill in your own values.
# `.env.local` is gitignored — never commit real keys.
#
# PostHog product analytics.
# The project API key is a WRITE-ONLY ingest key and is safe to ship in a
# frontend bundle. Find it in PostHog under: Settings → Project → Project API Key.
VITE_POSTHOG_KEY=phc_your_project_api_key_here

# Your PostHog region host. Use the one shown in your PostHog project settings:
#   US cloud  -> https://us.i.posthog.com   (default if unset)
#   EU cloud  -> https://eu.i.posthog.com
VITE_POSTHOG_HOST=https://us.i.posthog.com
